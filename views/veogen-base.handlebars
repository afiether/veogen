<style>

/* utility classes */
.hidden { display: none !important; }
</style>

<div id="background-container" style="z-index: 1;"></div>

<div class="glitch-wrapper" id="frag-glitch" style="display:none;">
  <h1 class="glitch" data-text=""></h1>
</div>

<div class="tech-scene">
  <div class="tech-bar" id="frag-tech-bar"></div>

  <h1 id="frag-title"></h1>
  <h2 id="frag-subtitle" class="hidden"></h2>


  <div class="content-text">
    <div id="frag-enlarge-space" style="display:none;"></div>
    <p id="frag-text"></p>

    

    <ul id="frag-ulist"></ul>

    <ol id="frag-olist"></ol>
  </div>

  <div id="frag-showcase-container" style="text-align: center;  white-space: nowrap; margin: 1.5em 0; z-index: 10;"></div>


  <div class="terminal hidden" id="frag-terminal" style="z-index: 10;">
    <div class="terminal-header" id="frag-terminal-header"></div>
    <div class="terminal-line">
      <span class="prompt">$</span>
      <span class="typing"></span>
    </div>
  </div>

  <div class="matrix-container hidden" id="frag-matrix">

    <div class="matrix-lines"></div>

    <h1 class="matrix-title" id="frag-matrix-title"></h1>

  </div>

  <div class="caption-text" id="caption-container"></div>



{{!-- Flags for Puppeteer --}}
<div id="animations-finished"></div>
<div id="page-loaded"></div>

<script>
  // Terminal typing effect and animation driver
  let terminalText = {{{ toJSON terminalPrompt }}} || '';
  const terminalSleep = {{{ toJSON terminalSleep }}} || 230;
  let i = 0;

  function type(){
    if(i < terminalText.length){
      $('.typing').append(terminalText.charAt(i));
      i++;
      setTimeout(type,terminalSleep);
    }
  }
  setTimeout(type, terminalSleep);
  //$(document).ready(type)

  $(document).ready(function() {
    // Custom visual elements
    const animationsFinishedFlag = $('#animations-finished');
    const pageLoadedFlag = $('#page-loaded');
    const pending = new Set();       // “stack” of active animations

    function markStart(id) { pending.add(id); }
    function markEnd(id) {
        pending.delete(id);
        if (pending.size === 0) {
            animationsFinishedFlag.attr('data-animations-finished','TRUE');
            console.log('All animations finished');
        }
    }

    // wrapper that returns the jQuery node to animate
    function getElement(def) {
        if (def.selector) {
            return $(def.selector);             // existing element
        }
        // otherwise create a new one
        const el = $(`<${def.type}/>`);
        if (def.id) el.attr('id', def.id);
        if (def.attr) el.attr(def.attr);
        if (def.innerHtml) el.html(def.innerHtml);
        $('body').append(el);                  // or insert wherever you need
        return el;
    }

    function applyDefinitions(el, def, uid) {
        if (def.css) el.css(def.css);

        // css‑animation: if you just set CSS that triggers a @keyframes animation
        // you can listen for animationend on the element itself:
        if (def.css && def.css.animationName) {
            el.on('animationend webkitAnimationEnd', () => markEnd(uid));
            markStart(uid);
        }

        // jQuery animate
        if (def.animate) {
            markStart(uid);
            el.animate(def.animate.properties || {}, def.animate.options || 400,
                       () => markEnd(uid));
        }

        // jQuery UI effect
        if (def.effect) {
            markStart(uid);
            el.effect(def.effect.name, def.effect.options || {},
                      def.effect.options || 400, () => markEnd(uid));
        }
    }



    // helper functions for captions, fragments, and slideshow -------------------
    function escapeHtml(str) {
        return String(str).replace(/[&<>\"']/g, function(ch) {
            return ({'&':'&amp;','<':'&lt;','>':'&gt;','\"':'&quot;',"'":'&#39;'})[ch];
        });
    }

    function renderCaptionWordsJs(arr) {
        if (!Array.isArray(arr)) return '';
        return arr.map(w => {
            const word = escapeHtml(w.word || '');
            const start = Number(w.start) || 0;
            const end = Number(w.end) || 0;
            return `<span class=\"caption-word\" data-start=\"${start}\" data-end=\"${end}\">${word}</span>`;
        }).join(' ');
    }

    function updateCaptions(timeMs) {
      let lastEnd = 0;
      $('.caption-word').each(function() {
        const start = parseInt($(this).attr('data-start'));
        const end   = parseInt($(this).attr('data-end'));
        if (!isNaN(start) && !isNaN(end) && timeMs >= start && timeMs <= end) {
          $(this).addClass('highlight');
        } else {
          $(this).removeClass('highlight');
        }

        if (!isNaN(end) && end > lastEnd) {
          lastEnd = end;
        }
      });

      if (timeMs > lastEnd) {
        return false;
      }

      return true;
    }

    const expectedDuration = {{ toJSON expectedDuration }} || 2200;
    const techBarDelay = 300;

    function applyFragment(frag, idx, count) {
        console.log('applying fragment', idx, frag);
        if (frag.title) $('#frag-title').html(frag.title);
        if (frag.subtitle) {
            if (frag.subtitle) $('#frag-subtitle').html(frag.subtitle).removeClass('hidden');
            else $('#frag-subtitle').addClass('hidden');
        }
        if (frag.glitchTitle) {
            if (frag.glitchTitle) {
                $('#frag-glitch').show();
                $('#frag-glitch .glitch').attr('data-text', frag.glitchTitle).html(frag.glitchTitle);
            } else {
                $('#frag-glitch').hide();
            }
        }
        if (frag.backgroundColor) {
            $('body').css('background-color', frag.backgroundColor);
        }
        if (idx === 0) {
          // Only for the first slide, set the background image/video. This prevents jarring changes if media is different between fragments
          if (frag.backgroundImage) {
              $('#background-container').html(`<img id="backgroundImage" src="${frag.backgroundImage}" class="backgroundImage"/>`);
          } else if (frag.backgroundVideo) {
              $('#background-container').html(`<video autoplay muted loop class="backgroundVideo"><source src="${frag.backgroundVideo}" type="video/mp4"></video>`);
          } else {
              $('#background-container').empty();
          }
        }
        if (frag.enlargeSpace) {
            $('#frag-enlarge-space').css('height', frag.enlargeSpace).show();
        } else {
            $('#frag-enlarge-space').hide();
        }
        if (frag.text) $('#frag-text').html(frag.text);
        if (Array.isArray(frag.ulist)) {
            const ul = $('#frag-ulist').empty();
            frag.ulist.forEach(item => ul.append(`<li>${item}</li>`));
        }
        if (Array.isArray(frag.olist)) {
            const ol = $('#frag-olist').empty();
            frag.olist.forEach(item => ol.append(`<li>${item}</li>`));
        }
        if (frag.showcaseImage) {
            $('#frag-showcase-container').html(`<img id="showcaseImage" src="${frag.showcaseImage}" style="border-radius:25px;vertical-align:middle;"/>`);
        } else {
            $('#frag-showcase-container').empty();
        }
        if (frag.terminalHeader) {
            $('#frag-terminal-header').html(frag.terminalHeader);
            if (frag.terminalPrompt) {
                $('#frag-terminal').removeClass('hidden');
                $('.typing').empty();
                i = 0;
                type();
                terminalText = frag.terminalPrompt;
            } else {
                $('#frag-terminal').addClass('hidden');
            }
        }
        if (frag.matrixTitle) {
            if (frag.matrixTitle) {
                $('#frag-matrix-title').html(frag.matrixTitle);
                $('#frag-matrix').removeClass('hidden');
                $('#frag-matrix .matrix-lines').css('left','0');
                $('#frag-matrix .matrix-lines').animate({left:'-50%'},3000);
                $('#frag-matrix .matrix-title').css({opacity:0,transform:'translateY(40px)'});
                $('#frag-matrix .matrix-title').delay(400).animate({opacity:1},{duration:900,step:function(now){const y=40-now*40;$(this).css('transform',`translateY(${y}px)`);}});
            } else {
                $('#frag-matrix').addClass('hidden');
            }
        }
        if (Array.isArray(frag.captions)) {
            $('#caption-container').html(renderCaptionWordsJs(frag.captions));
        } else {
            $('#caption-container').empty();
        }
        //clearVisuals();
        if (Array.isArray(frag.visualElements)) {
            frag.visualElements.forEach((def,i) => {
                const uid = def.id || `ve_${i}`;
                const el = getElement(def);
                activeVisuals.push(el);
                applyDefinitions(el, def, uid);
            });
        }
        $('.content-text').stop(true,true).css({opacity:0,transform:'translateY(80px)'});
        $('.content-text').animate({opacity:1},{duration:900,step:function(now){const y=80-now*80;$(this).css('transform',`translateY(${y}px)`);}});
        //$('#frag-tech-bar').stop(true,true).css('width','0');
        //$('#frag-tech-bar').delay(techBarDelay).animate({width:'95%'}, expectedDuration);

      // caption utility functions --------------------------------------------------
      

      // We disable this for now
      const audioVideoElements = $('audio');

      if (audioVideoElements.length > 0) {
        // if there's an audio/video element on the page we automatically hook it
        $('audio, video').on('timeupdate', function() {
          // convert seconds to milliseconds
          const ms = this.currentTime * 1000;
          updateCaptions(ms);
        });
      } else {
        let startTime = 0;
        // if no media element, we can use a simple timer to drive captions
        const captionInterval = setInterval(() => {
          if (!updateCaptions(startTime)) {
            clearInterval(captionInterval);
          }
          startTime += 100; // update every 100ms
        }, 100);
      }
    }

    function scheduleFragments(frags) {
        frags.sort((a,b)=>a.startsAt - b.startsAt);
        frags.forEach((frag,i)=>{
            setTimeout(()=>applyFragment(frag,i,frags.length), frag.startsAt);
        });
        const last = frags[frags.length-1];
        const totalEnd = (last.startsAt||0) + expectedDuration + techBarDelay;
        setTimeout(()=>markEnd(), totalEnd);
    }

    // data passed from server
    const fragments = {{{ toJSON fragments }}} || null;

    // initial fragment rendering
    if (Array.isArray(fragments) && fragments.length) {
        scheduleFragments(fragments);
    } else {
        const initialData = {
            title: {{{ toJSON title }}},
            subtitle: {{{ toJSON subtitle }}},
            backgroundColor: {{{ toJSON backgroundColor }}},
            backgroundImage: {{{ toJSON backgroundImage }}},
            backgroundVideo: {{{ toJSON backgroundVideo }}},
            glitchTitle: {{{ toJSON glitchTitle }}},
            text: {{{ toJSON text }}},
            ulist: {{{ toJSON ulist }}},
            olist: {{{ toJSON olist }}},
            showcaseImage: {{{ toJSON showcaseImage }}},
            terminalHeader: {{{ toJSON terminalHeader }}},
            terminalPrompt: {{{ toJSON terminalPrompt }}},
            matrixTitle: {{{ toJSON matrixTitle }}},
            captions: {{{ toJSON captions }}},
            visualElements: {{{ toJSON visualElements }}},
            enlargeSpace: {{{ toJSON enlargeSpace }}},
        };
        applyFragment(initialData, 0, 1);
        if (!Array.isArray(initialData.visualElements) || initialData.visualElements.length <=0) {
            setTimeout(()=>markEnd(), expectedDuration + techBarDelay);
        }
    }

    // global glitch animation (runs even if .glitch is hidden)
    setInterval(function(){
      $('.glitch').css('transform',
        `translate(${Math.random()*16-3}px,${Math.random()*26-3}px)`
      );
      setTimeout(()=>{$('.glitch').css('transform','translate(0,0)');},80);
    },1200);

    
    
    $('#frag-tech-bar').delay(techBarDelay).animate({width:'95%'}, expectedDuration);

    // FINISH
    pageLoadedFlag.attr('data-loaded', 'TRUE');
  });

  
</script>
