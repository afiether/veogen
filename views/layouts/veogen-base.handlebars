<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width={{renderWidth}}, height={{renderHeight}}, initial-scale=1.0">
<title>AFIEther</title>
<style>
  
  .container {
    width: {{renderWidth}}px;
    height: {{renderHeight}}px;
    //background-image: url('img/cover-veogen.png');
    background-size: initial;
    background-repeat: no-repeat;
    background-color: {{backgroundColor}}; /* fallback color */
    margin: 0;
    padding: 0;
    height: 100vh;
    overflow: hidden;
  }

  .gradient-text {
    font-size: 38px;
    font-weight: bold;
    background: linear-gradient(90deg, #9d4992, #ec724a);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }
  .content-text{ 
    position: absolute; top: 140px;  font-size: 65px; color: #0e0d0d;  z-index: 10; width: 96%; padding: 70px;
    font-family: Montserrat, sans-serif;
  }
  .helper {
      display: inline-block;
      height: 100%;
      vertical-align: middle;
  }

  .backgroundImage {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .backgroundVideo {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 1;
  }

  .other-text {
    position: relative;
    font-size: 24px;
    color: #333;
    z-index: 10;
    width: 80%;
  }
  
</style>
{{> google-fonts}}
{{> jquery}}
</head>
<body class="container">

{{{body}}}

</body>
</html>
